{
  "hosting": [
    {
      "target": "marmicode",
      "public": "dist/apps/marmicode/browser",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "*.*.@(css|js)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public,max-age=31536000,immutable"
            }
          ]
        }
      ],
      "redirects": [
        {
          "source": "/workshops/pragmatic-angular-testing-full-course",
          "destination": "/workshops/pragmatic-angular-testing",
          "type": 301
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "trailingSlash": false
    }
  ]
}
